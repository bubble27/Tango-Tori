<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup config: never back up or device-transfer the encrypted
     user API key (see backup_rules.xml for the pre-12 equivalent). -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
